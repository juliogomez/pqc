# Post-quantum SSH lab - server (sshd) config. See ssh/README.md.
#
# Started by hand inside the ssh-server container:
#   /usr/local/sbin/sshd -D -e -f /cfg/sshd_config
# (-D foreground, -e log to stderr). The reader drives it so the exercises can
# stop/edit/restart it freely.

Port 22
ListenAddress 0.0.0.0

# Lab-only: the host + user keys live in the bind-mounted /cfg, whose ownership
# comes from the host, so relax sshd's strict owner/permission checks.
StrictModes no

# Host key generated by gen-keys.sh. Classical Ed25519 to start; reissue as the
# composite post-quantum type with `docker compose run --rm keygen mldsa44-ed25519`.
HostKey /cfg/ssh_host_key

PidFile /run/sshd.pid
LogLevel VERBOSE

# Public-key auth only; the lab user's key is the sole authorized_keys entry.
PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no
AuthorizedKeysFile /cfg/authorized_keys

# --- Exercise 4: post-quantum authentication --------------------------------
# The composite Ed25519+ML-DSA-44 signature (OpenSSH 10.4) is experimental and
# OFF by default, so it must be named explicitly. Uncomment these two lines to
# let sshd offer the post-quantum host key and accept the post-quantum user key.
# (List the exact names in-container with: ssh -Q HostKeyAlgorithms | grep mldsa)
#HostKeyAlgorithms ssh-mldsa44-ed25519@openssh.com
#PubkeyAcceptedAlgorithms ssh-mldsa44-ed25519@openssh.com
